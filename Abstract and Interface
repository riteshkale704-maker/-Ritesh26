public class Main {
    // Interface
    interface PaymentGateway {
        void processPayment(double amount);
    }

    // Abstract class
    static abstract class Payment {
        String transactionId;

        Payment(String transactionId) {
            this.transactionId = transactionId;
        }

        void showTransaction() {
            System.out.println("Transaction ID: " + transactionId);
        }

        abstract void paymentType();
    }

    // Derived class
    static class CreditCardPayment extends Payment implements PaymentGateway {

        CreditCardPayment(String id) {
            super(id);
        } // <-- Missing brace was here

        void paymentType() {
            System.out.println("Payment Method: Credit Card");
        }

        public void processPayment(double amount) {
            System.out.println("Processing payment of Rs." + amount);
        }
    }

    // Main method
    public static void main(String[] args) {
        CreditCardPayment p = new CreditCardPayment("TXN1001");
        p.showTransaction();
        p.paymentType();
        p.processPayment(5000);
    }
}

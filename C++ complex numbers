//Experiment 01 – C++ Complex Number

#include <iostream>
using namespace std;
class Complex {
    float real, imag;
public:
    void input() {
        cout << "Enter real part: ";
        cin >> real;
        cout << "Enter imaginary part: ";
        cin >> imag;
    }
    void display() {
        if (imag >= 0)
            cout << real << " + " << imag << "i";
        else
            cout << real << " - " << -imag << "i";
    }
    Complex add(Complex c) {
        Complex temp;
        temp.real = real + c.real;
        temp.imag = imag + c.imag;
        return temp;
    }
    Complex subtract(Complex c) {
        Complex temp;
        temp.real = real - c.real;
        temp.imag = imag - c.imag;
        return temp;
    }
    Complex multiply(Complex c) {
        Complex temp;
        temp.real = (real * c.real) - (imag * c.imag);
        temp.imag = (real * c.imag) + (imag * c.real);
        return temp;
    }
    Complex divide(Complex c) {
        Complex temp;
        float denominator = (c.real * c.real) + (c.imag * c.imag);
        if (denominator == 0) {
            cout << "\nError: Division by zero!";
            temp.real = temp.imag = 0;
            return temp;
        }
        temp.real = ((real * c.real) + (imag * c.imag)) / denominator;
        temp.imag = ((imag * c.real) - (real * c.imag)) / denominator;
        return temp;
    }
    Complex conjugate() {
        Complex temp;
        temp.real = real;
        temp.imag = -imag;
        return temp;
    }
};
int main() {
    Complex c1, c2, result;
    cout << "Enter first complex number:\n";
    c1.input();
    cout << "\nEnter second complex number:\n";
    c2.input();
    cout << "\nAddition: ";
    result = c1.add(c2);
    result.display();
    cout << "\nSubtraction: ";
    result = c1.subtract(c2);
    result.display();
    cout << "\nMultiplication: ";
    result = c1.multiply(c2);
    result.display();
    cout << "\nDivision: ";
    result = c1.divide(c2);
    result.display();
    cout << "\nConjugate: ";
    result = c1.conjugate();
    result.display();
    return 0;
}

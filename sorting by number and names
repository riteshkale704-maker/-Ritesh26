A]Sorting by number
import java.util.*;
public class SortIntegers {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter n: ");
        int n = sc.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++)
            arr[i] = sc.nextInt();
        Arrays.sort(arr);
        System.out.println("Sorted:");
        for (int x : arr)
            System.out.print(x + " ");
        sc.close();
    }
}

B] Sort by Names

import java.util.*;
public class SortNames {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter n: ");
        int n = sc.nextInt();
        sc.nextLine();
        String[] names = new String[n];
        for (int i = 0; i < n; i++)
            names[i] = sc.nextLine();
        Arrays.sort(names);
        System.out.println("Sorted Names:");
        for (String s : names)
            System.out.println(s);
        sc.close();
    }
}
